    {
      "id": "v7K1aB739PKGQfr9uHXi3",
      "type": "text",
      "x": 268.585328799833,
      "y": 3715.29100062935,
      "width": 699.1597290039062,
      "height": 245,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
