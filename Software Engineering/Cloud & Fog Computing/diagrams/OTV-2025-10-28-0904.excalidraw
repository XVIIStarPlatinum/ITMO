    {
      "id": "_kfjktUS7J9dhDPRjz3-N",
      "type": "text",
      "x": 1894.2799773568856,
      "y": 983.1882706517852,
      "width": 712.095703125,
      "height": 245,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 363028461,
      "version": 289,
      "versionNonce": 1027556835,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1761669255351,
      "link": null,
      "locked": false,
      "text": "1. Key-value store\n2. Можно заменить на то что известно и под рукой\n  - Consult\n  - Etcd\n  - ZooKeeper\n3. В нём храним все адреса кластера\n4. Всегда реплицируется и работает в режиме НА",
      "fontSize": 28,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 235,
      "containerId": null,
      "originalText": "1. Key-value store\n2. Можно заменить на то что известно и под рукой\n  - Consult\n  - Etcd\n  - ZooKeeper\n3. В нём храним все адреса кластера\n4. Всегда реплицируется и работает в режиме НА",
      "lineHeight": 1.25
    },
