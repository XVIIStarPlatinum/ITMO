    {
      "id": "y3I9J5Rk9oerQGkZSdLsa",
      "type": "text",
      "x": 317.5628040381441,
      "y": 2676.1608870562254,
      "width": 657.4677734375,
      "height": 630,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 821175043,
      "version": 601,
      "versionNonce": 404148579,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1761670513881,
      "link": null,
      "locked": false,
      "text": "1. Constraints:\n  - Использовать конкретный узел\n  - Определённый Storage Driver\n  - Определённый Execution Driver\n  - Определённая версия ядра Linux\n  - Определённая версия операционной системы\n\n2. Resources\n  - Количество Container Slots на узле\n  - Доступные порты\n  - Custom Hardware\n\n3. Containers\n  - Affinity filters\n  - Container name/id\n  - Доступность образа на узле\n  - Custom labels\n  - Зависимости",
      "fontSize": 28,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 620,
      "containerId": null,
      "originalText": "1. Constraints:\n  - Использовать конкретный узел\n  - Определённый Storage Driver\n  - Определённый Execution Driver\n  - Определённая версия ядра Linux\n  - Определённая версия операционной системы\n\n2. Resources\n  - Количество Container Slots на узле\n  - Доступные порты\n  - Custom Hardware\n\n3. Containers\n  - Affinity filters\n  - Container name/id\n  - Доступность образа на узле\n  - Custom labels\n  - Зависимости",
      "lineHeight": 1.25
    },
